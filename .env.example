# Required: Anthropic API key for AI features
ANTHROPIC_API_KEY=sk-ant-...

# Database (from Supabase - used in prisma/prisma.config.ts)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Local dev bypass (your email for local testing)
DEV_USER_EMAIL=you@example.com
